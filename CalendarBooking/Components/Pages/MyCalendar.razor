@page "/my"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using CalendarBooking.Domain
@using CalendarBooking.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@inject AvailabilityService Availability
@inject AvailabilityRuleService Rules
@inject BookingService Booking
@inject ApprovalService Approvals
@inject CancellationService Cancellations
@inject SubscriptionService Subscriptions
@inject UserManager<ApplicationUser> UserManager
@inject GoogleCalendarConnector Calendar
@inject MicrosoftCalendarConnector MicrosoftCalendar
@inject NavigationManager Nav
@inject IJSRuntime JS

@* PROTECTED + INTERACTIVE. [Authorize] gates it: anonymous users are redirected to login
   server-side during prerender (Routes.razor -> RedirectToLogin). The data load and the
   browser-timezone lookup happen in OnAfterRenderAsync, the first point where JS is
   available, so until then the page shows "Loading…". Mobile-first: single column on
   phones, two columns from large screens up. *@

<PageTitle>My Calendar</PageTitle>

<h1>My Calendar</h1>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else
{
    @if (calendarStatus is not null)
    {
        <div class="alert alert-info" role="alert">@calendarStatus</div>
    }

    @if (newSubscribers.Count > 0)
    {
        <div class="alert alert-success" role="alert">
            You got @newSubscribers.Count new subscriber@(newSubscribers.Count == 1 ? "" : "s"):
            @string.Join(", ", newSubscribers.Take(25).Select(s => s.Nickname))@(newSubscribers.Count > 25 ? $", and {newSubscribers.Count - 25} more" : "").
        </div>
    }

    @* Shared view controls — Week/Month + period navigation. Apply to BOTH calendars. *@
    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
        <div class="btn-group btn-group-sm" role="group" aria-label="View">
            <button class="btn @(view == ViewMode.Week ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetView(ViewMode.Week)">Week</button>
            <button class="btn @(view == ViewMode.Month ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetView(ViewMode.Month)">Month</button>
        </div>
        <div class="btn-group btn-group-sm" role="group" aria-label="Navigate">
            <button class="btn btn-outline-secondary" @onclick="PrevPeriod" title="Previous @PeriodWord">&lsaquo;</button>
            <button class="btn btn-outline-secondary" @onclick="Today">Today</button>
            <button class="btn btn-outline-secondary" @onclick="NextPeriod" title="Next @PeriodWord">&rsaquo;</button>
        </div>
        <span class="fw-semibold">@PeriodLabel</span>
    </div>

    <h2 class="h5 mb-3">Your calendar</h2>

    <div class="card mb-4" style="max-width: 40rem;">
        <div class="card-body">
            <h2 class="h6 card-title">Google Calendar</h2>
            @if (!calendarConfigured)
            {
                <p class="text-muted small mb-0">Google Calendar sync isn't configured on this server.</p>
            }
            else if (calendarConnected)
            {
                <p class="small mb-2">Connected — your confirmed bookings are pushed to Google Calendar.</p>
                <form action="Account/Calendar/Disconnect" method="post">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Disconnect</button>
                </form>
            }
            else
            {
                <p class="small mb-2">Connect to push your confirmed bookings to Google Calendar.</p>
                <a class="btn btn-primary btn-sm" href="Account/Calendar/Connect">Connect Google Calendar</a>
            }
        </div>
    </div>

    <div class="card mb-4" style="max-width: 40rem;">
        <div class="card-body">
            <h2 class="h6 card-title">Microsoft Calendar</h2>
            @if (!msConfigured)
            {
                <p class="text-muted small mb-0">Microsoft Calendar sync isn't configured on this server.</p>
            }
            else if (msConnected)
            {
                <p class="small mb-2">Connected — your confirmed bookings are pushed to Outlook.</p>
                <form action="Account/Calendar/DisconnectMicrosoft" method="post">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Disconnect</button>
                </form>
            }
            else
            {
                <p class="small mb-2">Connect to push your confirmed bookings to Microsoft/Outlook Calendar.</p>
                <a class="btn btn-primary btn-sm" href="Account/Calendar/ConnectMicrosoft">Connect Microsoft Calendar</a>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h5 card-title">Weekly bookable hours</h2>
                    <p class="text-muted small">Pick days and a window; slots are created for the coming weeks (capped at year-end).</p>

                    @if (weeklyError is not null)
                    {
                        <div class="alert alert-danger py-2" role="alert">@weeklyError</div>
                    }
                    @if (weeklyMessage is not null)
                    {
                        <div class="alert alert-success py-2" role="alert">@weeklyMessage</div>
                    }

                    <div class="mb-3 d-flex flex-wrap gap-3">
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkMon" /> Mon</label>
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkTue" /> Tue</label>
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkWed" /> Wed</label>
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkThu" /> Thu</label>
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkFri" /> Fri</label>
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkSat" /> Sat</label>
                        <label class="form-check-label small"><input type="checkbox" class="form-check-input me-1" @bind="wkSun" /> Sun</label>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">From</label>
                            <input type="time" step="900" class="form-control" @bind="wkStart" />
                        </div>
                        <div class="col">
                            <label class="form-label">To</label>
                            <input type="time" step="900" class="form-control" @bind="wkEnd" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slot length (minutes)</label>
                        <input type="number" min="30" step="15" class="form-control" @bind="wkSlotMinutes" />
                        <small class="form-text text-muted">At least 30, in 15-minute steps; slots end on the quarter hour.</small>
                    </div>
                    @if (!wkStanding)
                    {
                        <div class="mb-3">
                            <label class="form-label">Weeks ahead</label>
                            <input type="number" min="1" max="60" class="form-control" @bind="wkWeeks" />
                            <small class="form-text text-muted">Capped at the end of the year.</small>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Booking type</label>
                        <select class="form-select" @bind="wkType">
                            <option value="@SlotType.ApprovalRequired">Ask my approval first</option>
                            <option value="@SlotType.Instant">Confirm instantly</option>
                        </select>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="wkStanding" @bind="wkStanding" />
                        <label class="form-check-label small" for="wkStanding">Keep updated automatically (standing rule)</label>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="GenerateWeeklyAsync">
                        @(wkStanding ? "Save standing rule" : "Create weekly availability")
                    </button>

                    @if (rules.Count > 0)
                    {
                        <hr />
                        <p class="small fw-semibold mb-1">Standing rules</p>
                        <ul class="list-group">
                            @foreach (var r in rules)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center gap-2">
                                    <span class="small">@DescribeRule(r)</span>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => DeleteRuleAsync(r.Id)">Delete</button>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h2 class="h5 card-title">Open to book (one-off)</h2>

                    @if (error is not null)
                    {
                        <div class="alert alert-danger py-2" role="alert">@error</div>
                    }

                    <EditForm Model="form" OnValidSubmit="AddSlotAsync">
                        <div class="mb-3">
                            <label class="form-label" for="start">Start</label>
                            <InputDate Type="InputDateType.DateTimeLocal" id="start" class="form-control" step="900" @bind-Value="form.Start" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="end">End</label>
                            <InputDate Type="InputDateType.DateTimeLocal" id="end" class="form-control" step="900" @bind-Value="form.End" />
                        </div>
                        <small class="form-text text-muted">Times must be on the quarter hour (:00, :15, :30, :45).</small>
                        <div class="mb-3">
                            <label class="form-label" for="type">When someone books this</label>
                            <InputSelect id="type" class="form-select" @bind-Value="form.SlotType">
                                <option value="@SlotType.Instant">Confirm instantly</option>
                                <option value="@SlotType.ApprovalRequired">Ask my approval first</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="weeks">Repeat weekly</label>
                            <InputNumber id="weeks" class="form-control" @bind-Value="form.Weeks" min="1" max="52" />
                            <small class="form-text text-muted">1 = a single slot. More creates the same time each week.</small>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Add slot@(form.Weeks > 1 ? "s" : "")</button>
                    </EditForm>

                    <p class="text-muted small mt-3 mb-0">Times are in your timezone (@tzLabel).</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7">
            <h2 class="h5">Availability — @PeriodLabel</h2>

            @if (PeriodSlots.Count == 0)
            {
                <p class="text-muted">No availability this @PeriodWord. Add a slot, or change the view above.</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var slot in PeriodSlots)
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <div class="fw-semibold">@FormatRange(slot.StartUtc, slot.EndUtc)</div>
                                    <span class="badge @(slot.SlotType == SlotType.Instant ? "bg-success" : "bg-warning text-dark")">
                                        @(slot.SlotType == SlotType.Instant ? "Instant" : "Approval")
                                    </span>
                                    @if (slot.IsBooked)
                                    {
                                        <span class="badge bg-secondary">Booked by @AttendeeFor(slot.Id)</span>
                                    }
                                </div>
                                <button class="btn btn-outline-danger btn-sm" disabled="@slot.IsBooked"
                                        @onclick="() => DeleteSlotAsync(slot.Id)">
                                    Delete
                                </button>
                            </div>

                            @* People trying to book this slot — accept (✓) or decline (✗) inline. *@
                            @foreach (var req in PendingFor(slot.Id))
                            {
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="small"><strong>@req.RequesterNickname</strong> wants to book this</span>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-success" title="Accept @req.RequesterNickname"
                                                @onclick="() => ApproveAsync(req.RequestId)">✓</button>
                                        <button class="btn btn-danger" title="Decline @req.RequesterNickname"
                                                @onclick="() => DeclineAsync(req.RequestId)">✗</button>
                                    </div>
                                </div>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <hr class="my-4" />

    @if (requests.Any(r => !InPeriod(r.StartUtc)))
    {
        <p class="text-muted small">
            @requests.Count(r => !InPeriod(r.StartUtc)) pending request(s) fall outside this @PeriodWord — navigate to their week/month to accept or decline.
        </p>
    }

    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 card-title">Book for a client</h2>
                    <p class="text-muted small">Confirm one of your open slots for someone you've booked with before.</p>
                    @{ var openSlots = slots.Where(s => !s.IsBooked).ToList(); }
                    @if (openSlots.Count == 0)
                    {
                        <p class="text-muted mb-0">You have no open slots to assign.</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label" for="obo-slot">Slot</label>
                            <select id="obo-slot" class="form-select" @bind="onBehalfSlotId">
                                <option value="">Choose a slot…</option>
                                @foreach (var slot in openSlots)
                                {
                                    <option value="@slot.Id">@FormatRange(slot.StartUtc, slot.EndUtc)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="obo-client">Client nickname</label>
                            <input id="obo-client" class="form-control" @bind="onBehalfClient" placeholder="their nickname" />
                        </div>
                        <button class="btn btn-primary w-100" @onclick="BookOnBehalfAsync">Book for them</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <h2 class="h5">My bookings</h2>
    @if (bookings.Count == 0)
    {
        <p class="text-muted">No upcoming bookings yet.</p>
    }
    else
    {
        <ul class="list-group" style="max-width: 46rem;">
            @foreach (var b in bookings)
            {
                <li class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <div class="fw-semibold">@FormatRange(b.StartUtc, b.EndUtc)</div>
                            <span class="text-muted small">
                                @if (b.ActingUserIsOwner)
                                {
                                    @($"with {b.AttendeeNickname} (you're hosting)")
                                }
                                else
                                {
                                    @($"hosted by {b.OwnerNickname}")
                                }
                            </span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-2 flex-wrap">
                        <input class="form-control form-control-sm" style="max-width: 24rem;"
                               placeholder="Reason for cancelling"
                               value="@GetReason(b.BookingId)"
                               @oninput="e => SetReason(b.BookingId, e.Value?.ToString())" />
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => CancelAsync(b.BookingId)">Cancel</button>
                    </div>
                </li>
            }
        </ul>
    }

    <hr class="my-4" />

    @* The link between the two calendars: pick a followed user to load their calendar below. *@
    <div class="card mb-3" style="max-width: 40rem;">
        <div class="card-body">
            <h2 class="h6 card-title">People you follow</h2>
            <p class="small mb-2">
                Your code: <strong>@myPublicId</strong>
                <span class="text-muted">— share it so others can subscribe to you.</span>
            </p>

            @if (subscribeMessage is not null)
            {
                <div class="alert alert-success py-2">@subscribeMessage</div>
            }
            @if (subscribeError is not null)
            {
                <div class="alert alert-danger py-2">@subscribeError</div>
            }

            <div class="d-flex gap-2 mb-3 flex-wrap">
                <input class="form-control form-control-sm" style="max-width: 16rem;"
                       placeholder="Enter a user's code" @bind="subscribeCode" />
                <button class="btn btn-primary btn-sm" @onclick="SubscribeByCodeAsync">Subscribe</button>
            </div>

            @if (subscriptions.Count == 0)
            {
                <p class="text-muted small mb-0">You're not subscribed to anyone yet. Subscribe with a code to book them below.</p>
            }
            else
            {
                <p class="small text-muted mb-1">Pick someone to load their calendar:</p>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var sub in subscriptions)
                    {
                        <div class="btn-group btn-group-sm" role="group">
                            <button class="btn @(selectedTargetId == sub.UserId ? "btn-primary" : "btn-outline-primary")"
                                    title="@sub.FullNameOrNickname"
                                    @onclick="() => SelectSubscribedAsync(sub)">
                                @sub.Nickname
                            </button>
                            <button class="btn btn-outline-secondary" title="Unsubscribe"
                                    @onclick="() => UnsubscribeAsync(sub.UserId)">&times;</button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <h2 class="h5 mb-3">Book a time</h2>
    @if (selectedTargetId is null)
    {
        <p class="text-muted">Pick someone you follow above to see their open times.</p>
    }
    else
    {
        <h3 class="h6">@selectedNickname</h3>
        @if (bookingMessage is not null)
        {
            <div class="alert alert-success" role="alert">@bookingMessage</div>
        }
        @if (bookingError is not null)
        {
            <div class="alert alert-danger" role="alert">@bookingError</div>
        }

        <p class="text-muted small mb-2">
            <span class="badge" style="background-color: #cfe2ff; color: #084298;">&nbsp;&nbsp;</span> bookable ·
            <span class="badge bg-secondary">&nbsp;&nbsp;</span> busy (details are private)
        </p>

        @if (PeriodBookingSlots.Count == 0)
        {
            <p class="text-muted">Nothing on their calendar this @PeriodWord.</p>
        }
        else
        {
            <ul class="list-group" style="max-width: 40rem;">
                @foreach (var slot in PeriodBookingSlots)
                {
                    @if (slot.IsBooked)
                    {
                        @* Busy — time only, no who/what, not bookable. *@
                        <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <span class="fw-semibold text-muted">@FormatRange(slot.StartUtc, slot.EndUtc)</span>
                            <span class="badge bg-secondary">Busy</span>
                        </li>
                    }
                    else
                    {
                        @* Bookable — light blue. *@
                        <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2" style="background-color: #cfe2ff;">
                            <div>
                                <div class="fw-semibold">@FormatRange(slot.StartUtc, slot.EndUtc)</div>
                                <span class="badge @(slot.SlotType == SlotType.Instant ? "bg-success" : "bg-warning text-dark")">
                                    @(slot.SlotType == SlotType.Instant ? "Instant" : "Approval")
                                </span>
                            </div>
                            <button class="btn btn-primary btn-sm" @onclick="() => BookFromCalendarAsync(slot)">
                                @(slot.SlotType == SlotType.Instant ? "Book" : "Request")
                            </button>
                        </li>
                    }
                }
            </ul>
        }
    }

    <hr class="my-4" />
    <p class="small"><a class="text-danger" href="Account/Close">Close my account</a></p>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private bool loaded;
    private string userId = "";
    private TimeZoneInfo tz = TimeZoneInfo.Utc;
    private string tzLabel = "UTC";
    private List<AvailabilitySlot> slots = new();
    private List<IncomingRequest> requests = new();
    private List<MyBooking> bookings = new();
    private Dictionary<Guid, string> attendeeBySlot = new();
    private readonly Dictionary<Guid, string> cancelReasons = new();
    private string? error;
    private readonly SlotForm form = new();

    // "Book for a client" form state.
    private string? onBehalfSlotId;
    private string? onBehalfClient;

    // Weekly bookable-hours generator state.
    private bool wkMon, wkTue, wkWed, wkThu, wkFri, wkSat, wkSun;
    private TimeOnly wkStart = new(9, 0);
    private TimeOnly wkEnd = new(17, 0);
    private int wkSlotMinutes = 30;
    private int wkWeeks = 4;
    private SlotType wkType = SlotType.ApprovalRequired;
    private bool wkStanding;
    private List<WeeklyAvailabilityRule> rules = new();
    private string? weeklyMessage;
    private string? weeklyError;

    // External calendar connection state.
    private bool calendarConfigured;
    private bool calendarConnected;
    private bool msConfigured;
    private bool msConnected;
    private string? calendarStatus;

    // Subscriptions.
    private string myPublicId = "";
    private List<SubscriptionView> subscriptions = new();
    private List<NewSubscriber> newSubscribers = new();
    private string? subscribeCode;
    private string? subscribeMessage;
    private string? subscribeError;

    // Second calendar: the followed user whose open times are shown for booking.
    private string? selectedTargetId;
    private string? selectedNickname;
    private List<CalendarSlot> bookingSlots = new();
    private string? bookingMessage;
    private string? bookingError;

    // Shared Week/Month view + the period being shown (applies to both calendars).
    private enum ViewMode { Week, Month }
    private ViewMode view = ViewMode.Week;
    private DateTime anchorLocal = DateTime.UtcNow.Date;

    private DateTime PeriodStartLocal => view == ViewMode.Week
        ? StartOfWeek(anchorLocal)
        : new DateTime(anchorLocal.Year, anchorLocal.Month, 1);
    private DateTime PeriodEndLocal => view == ViewMode.Week
        ? PeriodStartLocal.AddDays(7)
        : PeriodStartLocal.AddMonths(1);
    private DateTime PeriodStartUtc => TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(PeriodStartLocal, DateTimeKind.Unspecified), tz);
    private DateTime PeriodEndUtc => TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(PeriodEndLocal, DateTimeKind.Unspecified), tz);
    private string PeriodWord => view == ViewMode.Week ? "week" : "month";

    // ISO-8601 week number (Monday-based, matches our week start), shown in both views.
    private static int WeekOf(DateTime localDate) => System.Globalization.ISOWeek.GetWeekOfYear(localDate);

    private string PeriodLabel
    {
        get
        {
            if (view == ViewMode.Week)
            {
                return $"Week {WeekOf(PeriodStartLocal)} · {PeriodStartLocal:d MMM} – {PeriodEndLocal.AddDays(-1):d MMM yyyy}";
            }

            var firstWeek = WeekOf(PeriodStartLocal);
            var lastWeek = WeekOf(PeriodEndLocal.AddDays(-1));
            var weeks = firstWeek == lastWeek ? $"Week {firstWeek}" : $"Weeks {firstWeek}–{lastWeek}";
            return $"{PeriodStartLocal:MMMM yyyy} · {weeks}";
        }
    }

    private bool InPeriod(DateTime startUtc) => startUtc >= PeriodStartUtc && startUtc < PeriodEndUtc;

    // Both calendars' slots, scoped to the selected week/month.
    private IReadOnlyList<AvailabilitySlot> PeriodSlots => slots.Where(s => InPeriod(s.StartUtc)).ToList();
    private IReadOnlyList<CalendarSlot> PeriodBookingSlots => bookingSlots.Where(s => InPeriod(s.StartUtc)).ToList();

    // Monday-based week start.
    private static DateTime StartOfWeek(DateTime d) => d.Date.AddDays(-(((int)d.DayOfWeek + 6) % 7));

    private void SetView(ViewMode v) => view = v;
    private void PrevPeriod() => anchorLocal = view == ViewMode.Week ? anchorLocal.AddDays(-7) : anchorLocal.AddMonths(-1);
    private void NextPeriod() => anchorLocal = view == ViewMode.Week ? anchorLocal.AddDays(7) : anchorLocal.AddMonths(1);
    private void Today() => anchorLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, tz).Date;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Runs only once the circuit is live, so JS interop is available here.
        if (!firstRender)
        {
            return;
        }

        var state = await AuthState;
        userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";

        // Resolve the browser timezone so we can store UTC but show local times.
        try
        {
            var ianaId = await JS.InvokeAsync<string>("calendarBooking.getTimeZone");
            tz = TimeZoneInfo.FindSystemTimeZoneById(ianaId);
            tzLabel = tz.Id;
        }
        catch
        {
            tz = TimeZoneInfo.Utc;
            tzLabel = "UTC";
        }

        // Default the form to the next full hour, for a one-hour slot.
        var nowLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, tz);
        form.Start = new DateTime(nowLocal.Year, nowLocal.Month, nowLocal.Day, nowLocal.Hour, 0, 0).AddHours(1);
        form.End = form.Start.AddHours(1);

        // Anchor the week/month view on "today" in the user's timezone.
        anchorLocal = nowLocal.Date;

        // Google Calendar connection state + any status from the connect/disconnect redirect.
        calendarConfigured = Calendar.IsConfigured;
        calendarConnected = calendarConfigured && await Calendar.IsConnectedAsync(userId);
        msConfigured = MicrosoftCalendar.IsConfigured;
        msConnected = msConfigured && await MicrosoftCalendar.IsConnectedAsync(userId);
        myPublicId = (await UserManager.FindByIdAsync(userId))?.PublicId ?? "";

        // New-subscriber digest: show those gained since last visit (in subscribe order), then
        // advance the high-water mark so they aren't shown again. No push/email — login only.
        newSubscribers = (await Subscriptions.GetNewSubscribersAsync(userId)).ToList();
        if (newSubscribers.Count > 0)
        {
            await Subscriptions.MarkSubscribersSeenAsync(userId, newSubscribers.Max(s => s.SubscribedUtc));
        }
        var query = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        if (query.TryGetValue("calendar", out var calendarResult))
        {
            calendarStatus = calendarResult.ToString() switch
            {
                "connected" => "Google Calendar connected.",
                "disconnected" => "Google Calendar disconnected.",
                "unconfigured" => "Google Calendar sync isn't configured on this server.",
                _ => "Couldn't connect Google Calendar — please try again.",
            };
        }

        await LoadAsync();
        loaded = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        slots = (await Availability.GetUpcomingOwnedSlotsAsync(userId, DateTime.UtcNow)).ToList();
        requests = (await Approvals.GetIncomingRequestsAsync(userId, DateTime.UtcNow)).ToList();
        bookings = (await Cancellations.GetUpcomingBookingsForUserAsync(userId, DateTime.UtcNow)).ToList();
        subscriptions = (await Subscriptions.GetSubscriptionsAsync(userId)).ToList();
        rules = await Rules.GetRulesAsync(userId);

        // Map each of my booked slots to who booked it (one confirmed booking per slot).
        attendeeBySlot = bookings
            .Where(b => b.ActingUserIsOwner)
            .GroupBy(b => b.SlotId)
            .ToDictionary(g => g.Key, g => g.First().AttendeeNickname);
    }

    // Who booked my slot, and who's waiting on my approval for it.
    private string AttendeeFor(Guid slotId) => attendeeBySlot.TryGetValue(slotId, out var nickname) ? nickname : "someone";
    private IEnumerable<IncomingRequest> PendingFor(Guid slotId) => requests.Where(r => r.SlotId == slotId);

    private async Task SubscribeByCodeAsync()
    {
        subscribeMessage = subscribeError = null;
        if (string.IsNullOrWhiteSpace(subscribeCode))
        {
            subscribeError = "Enter a code.";
            return;
        }

        var result = await Subscriptions.SubscribeAsync(userId, subscribeCode, DateTime.UtcNow);
        if (!result.Ok)
        {
            subscribeError = result.Error;
            return;
        }

        subscribeCode = null;
        subscribeMessage = "Subscribed.";
        await LoadAsync();
    }

    private async Task UnsubscribeAsync(string targetId)
    {
        subscribeMessage = subscribeError = null;
        await Subscriptions.UnsubscribeAsync(userId, targetId);
        if (selectedTargetId == targetId)
        {
            selectedTargetId = null;
            selectedNickname = null;
            bookingSlots = new();
        }
        await LoadAsync();
    }

    private async Task SelectSubscribedAsync(SubscriptionView sub)
    {
        selectedTargetId = sub.UserId;
        selectedNickname = sub.Nickname;
        bookingMessage = bookingError = null;
        await LoadBookingSlotsAsync();
    }

    private async Task LoadBookingSlotsAsync()
    {
        if (selectedNickname is null)
        {
            return;
        }
        var (_, schedule) = await Booking.GetScheduleByNicknameAsync(selectedNickname, DateTime.UtcNow);
        bookingSlots = schedule.ToList();
    }

    private async Task BookFromCalendarAsync(CalendarSlot slot)
    {
        bookingMessage = bookingError = null;
        var result = slot.SlotType == SlotType.Instant
            ? await Booking.BookInstantAsync(slot.SlotId, userId, DateTime.UtcNow)
            : await Booking.RequestApprovalAsync(slot.SlotId, userId, DateTime.UtcNow);

        if (!result.Ok)
        {
            bookingError = result.Error;
        }
        else
        {
            bookingMessage = slot.SlotType == SlotType.Instant
                ? "Booked! It's on your calendar."
                : "Request sent — you'll hear back when the owner responds.";
        }

        await LoadBookingSlotsAsync();
        await LoadAsync(); // refresh "My bookings" / availability too
    }

    private string GetReason(Guid bookingId) => cancelReasons.TryGetValue(bookingId, out var r) ? r : "";

    private void SetReason(Guid bookingId, string? value) => cancelReasons[bookingId] = value ?? "";

    private async Task CancelAsync(Guid bookingId)
    {
        error = null;
        var result = await Cancellations.CancelAsync(bookingId, userId, GetReason(bookingId), DateTime.UtcNow);
        if (!result.Ok) { error = result.Error; return; }
        cancelReasons.Remove(bookingId);
        await LoadAsync();
    }

    private async Task ApproveAsync(Guid requestId)
    {
        error = null;
        var result = await Approvals.ApproveAsync(requestId, userId, DateTime.UtcNow);
        if (!result.Ok) { error = result.Error; }
        await LoadAsync();
    }

    private async Task DeclineAsync(Guid requestId)
    {
        error = null;
        var result = await Approvals.DeclineAsync(requestId, userId);
        if (!result.Ok) { error = result.Error; }
        await LoadAsync();
    }

    private async Task BookOnBehalfAsync()
    {
        error = null;
        if (!Guid.TryParse(onBehalfSlotId, out var slotId))
        {
            error = "Choose a slot first.";
            return;
        }
        if (string.IsNullOrWhiteSpace(onBehalfClient))
        {
            error = "Enter the client's nickname.";
            return;
        }

        var result = await Approvals.BookOnBehalfAsync(userId, slotId, onBehalfClient, DateTime.UtcNow);
        if (!result.Ok) { error = result.Error; return; }

        onBehalfSlotId = null;
        onBehalfClient = null;
        await LoadAsync();
    }

    private async Task GenerateWeeklyAsync()
    {
        weeklyMessage = weeklyError = null;

        var daysMask = 0;
        if (wkMon) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Monday);
        if (wkTue) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Tuesday);
        if (wkWed) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Wednesday);
        if (wkThu) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Thursday);
        if (wkFri) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Friday);
        if (wkSat) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Saturday);
        if (wkSun) daysMask |= WeeklyAvailability.DayBit(DayOfWeek.Sunday);

        if (daysMask == 0)
        {
            weeklyError = "Pick at least one day.";
            return;
        }
        if (wkEnd <= wkStart)
        {
            weeklyError = "Enter a valid From/To window.";
            return;
        }
        if (wkStart.Minute % 15 != 0 || wkEnd.Minute % 15 != 0)
        {
            weeklyError = "From/To must be on the quarter hour.";
            return;
        }
        if (wkSlotMinutes < 30 || wkSlotMinutes % 15 != 0)
        {
            weeklyError = "Slot length must be at least 30 minutes, in 15-minute steps.";
            return;
        }

        var startMin = (wkStart.Hour * 60) + wkStart.Minute;
        var endMin = (wkEnd.Hour * 60) + wkEnd.Minute;
        var nowUtc = DateTime.UtcNow;

        // Standing rule: persist it; the materializer keeps slots filled going forward.
        if (wkStanding)
        {
            var ruleResult = await Rules.AddRuleAsync(userId, daysMask, startMin, endMin, wkSlotMinutes, wkType, tz.Id, nowUtc);
            if (!ruleResult.Ok)
            {
                weeklyError = ruleResult.Error;
                return;
            }
            weeklyMessage = "Standing weekly rule saved — upcoming slots are kept filled automatically.";
            await LoadAsync();
            return;
        }

        // One-off: generate now for the chosen weeks ahead (capped at year-end).
        if (wkWeeks < 1)
        {
            weeklyError = "Weeks ahead must be at least 1.";
            return;
        }

        var nowLocal = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, tz);
        var cap = nowLocal.Month == 12 ? new DateTime(nowLocal.Year + 1, 1, 31) : new DateTime(nowLocal.Year, 12, 31);
        var endDate = nowLocal.Date.AddDays(wkWeeks * 7);
        if (endDate > cap.Date)
        {
            endDate = cap.Date;
        }

        var occurrences = WeeklyAvailability.Expand(daysMask, startMin, endMin, wkSlotMinutes, tz, nowLocal.Date, endDate, nowUtc);
        if (occurrences.Count == 0)
        {
            weeklyError = "No future slots in that range — check the days, window, and horizon.";
            return;
        }

        var result = await Availability.CreateManyAsync(userId, occurrences, wkType, nowUtc);
        if (!result.Ok)
        {
            weeklyError = result.Error;
            return;
        }

        weeklyMessage = "Weekly availability created (any times clashing with existing slots were skipped).";
        await LoadAsync();
    }

    private async Task DeleteRuleAsync(Guid ruleId)
    {
        weeklyMessage = weeklyError = null;
        await Rules.DeleteRuleAsync(userId, ruleId, DateTime.UtcNow);
        weeklyMessage = "Standing rule removed — its upcoming unbooked slots were cleared; booked ones are kept.";
        await LoadAsync();
    }

    private static readonly (DayOfWeek Day, string Label)[] DayLabels =
    {
        (DayOfWeek.Monday, "Mon"), (DayOfWeek.Tuesday, "Tue"), (DayOfWeek.Wednesday, "Wed"),
        (DayOfWeek.Thursday, "Thu"), (DayOfWeek.Friday, "Fri"), (DayOfWeek.Saturday, "Sat"), (DayOfWeek.Sunday, "Sun"),
    };

    private static string DescribeRule(WeeklyAvailabilityRule r)
    {
        var days = string.Join(" ", DayLabels.Where(d => (r.DaysMask & WeeklyAvailability.DayBit(d.Day)) != 0).Select(d => d.Label));
        var from = TimeSpan.FromMinutes(r.StartMinutes);
        var to = TimeSpan.FromMinutes(r.EndMinutes);
        var type = r.SlotType == SlotType.Instant ? "instant" : "approval";
        return $"{days} {from:hh\\:mm}–{to:hh\\:mm} · {r.SlotMinutes}m · {type}";
    }

    private async Task AddSlotAsync()
    {
        error = null;

        // The form holds local wall-clock time; convert to UTC for storage.
        var startUtc = TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(form.Start, DateTimeKind.Unspecified), tz);
        var endUtc = TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(form.End, DateTimeKind.Unspecified), tz);

        AvailabilityService.Result result;
        if (form.Weeks <= 1)
        {
            result = await Availability.CreateOneOffAsync(userId, startUtc, endUtc, form.SlotType, DateTime.UtcNow);
        }
        else
        {
            // Step the recurrence in LOCAL time and convert each occurrence to UTC, so a
            // weekly slot keeps the same wall-clock time even across a daylight-saving change.
            var occurrences = Enumerable.Range(0, form.Weeks)
                .Select(i =>
                {
                    var sLocal = form.Start.AddDays(7 * i);
                    var eLocal = form.End.AddDays(7 * i);
                    return (
                        StartUtc: TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(sLocal, DateTimeKind.Unspecified), tz),
                        EndUtc: TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(eLocal, DateTimeKind.Unspecified), tz));
                })
                .ToList();
            result = await Availability.CreateManyAsync(userId, occurrences, form.SlotType, DateTime.UtcNow);
        }

        if (!result.Ok)
        {
            error = result.Error;
            return;
        }

        await LoadAsync();
    }

    private async Task DeleteSlotAsync(Guid slotId)
    {
        error = null;
        var result = await Availability.DeleteAsync(userId, slotId);
        if (!result.Ok)
        {
            error = result.Error;
            return;
        }

        await LoadAsync();
    }

    private string FormatRange(DateTime startUtc, DateTime endUtc)
    {
        var start = TimeZoneInfo.ConvertTimeFromUtc(startUtc, tz);
        var end = TimeZoneInfo.ConvertTimeFromUtc(endUtc, tz);
        // Omit the date on the end when the slot stays within one day.
        var endText = end.Date == start.Date ? end.ToString("HH:mm") : end.ToString("ddd d MMM, HH:mm");
        return $"{start:ddd d MMM, HH:mm} – {endText}";
    }

    private sealed class SlotForm
    {
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public SlotType SlotType { get; set; } = SlotType.Instant;
        public int Weeks { get; set; } = 1;
    }
}
