@page "/my"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using CalendarBooking.Domain
@using CalendarBooking.Services
@inject AvailabilityService Availability
@inject ApprovalService Approvals
@inject CancellationService Cancellations
@inject IJSRuntime JS

@* PROTECTED + INTERACTIVE. [Authorize] gates it: anonymous users are redirected to login
   server-side during prerender (Routes.razor -> RedirectToLogin). The data load and the
   browser-timezone lookup happen in OnAfterRenderAsync, the first point where JS is
   available, so until then the page shows "Loading…". Mobile-first: single column on
   phones, two columns from large screens up. *@

<PageTitle>My Calendar</PageTitle>

<h1>My Calendar</h1>

@if (!loaded)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 card-title">Add availability</h2>

                    @if (error is not null)
                    {
                        <div class="alert alert-danger py-2" role="alert">@error</div>
                    }

                    <EditForm Model="form" OnValidSubmit="AddSlotAsync">
                        <div class="mb-3">
                            <label class="form-label" for="start">Start</label>
                            <InputDate Type="InputDateType.DateTimeLocal" id="start" class="form-control" @bind-Value="form.Start" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="end">End</label>
                            <InputDate Type="InputDateType.DateTimeLocal" id="end" class="form-control" @bind-Value="form.End" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="type">When someone books this</label>
                            <InputSelect id="type" class="form-select" @bind-Value="form.SlotType">
                                <option value="@SlotType.Instant">Confirm instantly</option>
                                <option value="@SlotType.ApprovalRequired">Ask my approval first</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="weeks">Repeat weekly</label>
                            <InputNumber id="weeks" class="form-control" @bind-Value="form.Weeks" min="1" max="52" />
                            <small class="form-text text-muted">1 = a single slot. More creates the same time each week.</small>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Add slot@(form.Weeks > 1 ? "s" : "")</button>
                    </EditForm>

                    <p class="text-muted small mt-3 mb-0">Times are in your timezone (@tzLabel).</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7">
            <h2 class="h5">Upcoming availability</h2>

            @if (slots.Count == 0)
            {
                <p class="text-muted">No upcoming slots yet. Add one to start offering times.</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var slot in slots)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <div class="fw-semibold">@FormatRange(slot.StartUtc, slot.EndUtc)</div>
                                <span class="badge @(slot.SlotType == SlotType.Instant ? "bg-success" : "bg-warning text-dark")">
                                    @(slot.SlotType == SlotType.Instant ? "Instant" : "Approval")
                                </span>
                                @if (slot.IsBooked)
                                {
                                    <span class="badge bg-secondary">Booked</span>
                                }
                            </div>
                            <button class="btn btn-outline-danger btn-sm" disabled="@slot.IsBooked"
                                    @onclick="() => DeleteSlotAsync(slot.Id)">
                                Delete
                            </button>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <hr class="my-4" />

    <div class="row g-4">
        <div class="col-12 col-lg-7">
            <h2 class="h5">Incoming requests</h2>
            @if (requests.Count == 0)
            {
                <p class="text-muted">No one is waiting on your approval.</p>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var req in requests)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <div class="fw-semibold">@FormatRange(req.StartUtc, req.EndUtc)</div>
                                <span class="text-muted small">from @req.RequesterNickname</span>
                            </div>
                            <div class="btn-group">
                                <button class="btn btn-success btn-sm" @onclick="() => ApproveAsync(req.RequestId)">Approve</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => DeclineAsync(req.RequestId)">Decline</button>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>

        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 card-title">Book for a client</h2>
                    <p class="text-muted small">Confirm one of your open slots for someone you've booked with before.</p>
                    @{ var openSlots = slots.Where(s => !s.IsBooked).ToList(); }
                    @if (openSlots.Count == 0)
                    {
                        <p class="text-muted mb-0">You have no open slots to assign.</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label" for="obo-slot">Slot</label>
                            <select id="obo-slot" class="form-select" @bind="onBehalfSlotId">
                                <option value="">Choose a slot…</option>
                                @foreach (var slot in openSlots)
                                {
                                    <option value="@slot.Id">@FormatRange(slot.StartUtc, slot.EndUtc)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="obo-client">Client nickname</label>
                            <input id="obo-client" class="form-control" @bind="onBehalfClient" placeholder="their nickname" />
                        </div>
                        <button class="btn btn-primary w-100" @onclick="BookOnBehalfAsync">Book for them</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <h2 class="h5">My bookings</h2>
    @if (bookings.Count == 0)
    {
        <p class="text-muted">No upcoming bookings yet.</p>
    }
    else
    {
        <ul class="list-group" style="max-width: 46rem;">
            @foreach (var b in bookings)
            {
                <li class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <div class="fw-semibold">@FormatRange(b.StartUtc, b.EndUtc)</div>
                            <span class="text-muted small">
                                @if (b.ActingUserIsOwner)
                                {
                                    @($"with {b.AttendeeNickname} (you're hosting)")
                                }
                                else
                                {
                                    @($"hosted by {b.OwnerNickname}")
                                }
                            </span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-2 flex-wrap">
                        <input class="form-control form-control-sm" style="max-width: 24rem;"
                               placeholder="Reason for cancelling"
                               value="@GetReason(b.BookingId)"
                               @oninput="e => SetReason(b.BookingId, e.Value?.ToString())" />
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => CancelAsync(b.BookingId)">Cancel</button>
                    </div>
                </li>
            }
        </ul>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private bool loaded;
    private string userId = "";
    private TimeZoneInfo tz = TimeZoneInfo.Utc;
    private string tzLabel = "UTC";
    private List<AvailabilitySlot> slots = new();
    private List<IncomingRequest> requests = new();
    private List<MyBooking> bookings = new();
    private readonly Dictionary<Guid, string> cancelReasons = new();
    private string? error;
    private readonly SlotForm form = new();

    // "Book for a client" form state.
    private string? onBehalfSlotId;
    private string? onBehalfClient;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Runs only once the circuit is live, so JS interop is available here.
        if (!firstRender)
        {
            return;
        }

        var state = await AuthState;
        userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";

        // Resolve the browser timezone so we can store UTC but show local times.
        try
        {
            var ianaId = await JS.InvokeAsync<string>("calendarBooking.getTimeZone");
            tz = TimeZoneInfo.FindSystemTimeZoneById(ianaId);
            tzLabel = tz.Id;
        }
        catch
        {
            tz = TimeZoneInfo.Utc;
            tzLabel = "UTC";
        }

        // Default the form to the next full hour, for a one-hour slot.
        var nowLocal = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, tz);
        form.Start = new DateTime(nowLocal.Year, nowLocal.Month, nowLocal.Day, nowLocal.Hour, 0, 0).AddHours(1);
        form.End = form.Start.AddHours(1);

        await LoadAsync();
        loaded = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        slots = (await Availability.GetUpcomingOwnedSlotsAsync(userId, DateTime.UtcNow)).ToList();
        requests = (await Approvals.GetIncomingRequestsAsync(userId, DateTime.UtcNow)).ToList();
        bookings = (await Cancellations.GetUpcomingBookingsForUserAsync(userId, DateTime.UtcNow)).ToList();
    }

    private string GetReason(Guid bookingId) => cancelReasons.TryGetValue(bookingId, out var r) ? r : "";

    private void SetReason(Guid bookingId, string? value) => cancelReasons[bookingId] = value ?? "";

    private async Task CancelAsync(Guid bookingId)
    {
        error = null;
        var result = await Cancellations.CancelAsync(bookingId, userId, GetReason(bookingId), DateTime.UtcNow);
        if (!result.Ok) { error = result.Error; return; }
        cancelReasons.Remove(bookingId);
        await LoadAsync();
    }

    private async Task ApproveAsync(Guid requestId)
    {
        error = null;
        var result = await Approvals.ApproveAsync(requestId, userId, DateTime.UtcNow);
        if (!result.Ok) { error = result.Error; }
        await LoadAsync();
    }

    private async Task DeclineAsync(Guid requestId)
    {
        error = null;
        var result = await Approvals.DeclineAsync(requestId, userId);
        if (!result.Ok) { error = result.Error; }
        await LoadAsync();
    }

    private async Task BookOnBehalfAsync()
    {
        error = null;
        if (!Guid.TryParse(onBehalfSlotId, out var slotId))
        {
            error = "Choose a slot first.";
            return;
        }
        if (string.IsNullOrWhiteSpace(onBehalfClient))
        {
            error = "Enter the client's nickname.";
            return;
        }

        var result = await Approvals.BookOnBehalfAsync(userId, slotId, onBehalfClient, DateTime.UtcNow);
        if (!result.Ok) { error = result.Error; return; }

        onBehalfSlotId = null;
        onBehalfClient = null;
        await LoadAsync();
    }

    private async Task AddSlotAsync()
    {
        error = null;

        // The form holds local wall-clock time; convert to UTC for storage.
        var startUtc = TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(form.Start, DateTimeKind.Unspecified), tz);
        var endUtc = TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(form.End, DateTimeKind.Unspecified), tz);

        var result = form.Weeks <= 1
            ? await Availability.CreateOneOffAsync(userId, startUtc, endUtc, form.SlotType, DateTime.UtcNow)
            : await Availability.CreateWeeklyAsync(userId, startUtc, endUtc, form.Weeks, form.SlotType, DateTime.UtcNow);

        if (!result.Ok)
        {
            error = result.Error;
            return;
        }

        await LoadAsync();
    }

    private async Task DeleteSlotAsync(Guid slotId)
    {
        error = null;
        var result = await Availability.DeleteAsync(userId, slotId);
        if (!result.Ok)
        {
            error = result.Error;
            return;
        }

        await LoadAsync();
    }

    private string FormatRange(DateTime startUtc, DateTime endUtc)
    {
        var start = TimeZoneInfo.ConvertTimeFromUtc(startUtc, tz);
        var end = TimeZoneInfo.ConvertTimeFromUtc(endUtc, tz);
        // Omit the date on the end when the slot stays within one day.
        var endText = end.Date == start.Date ? end.ToString("HH:mm") : end.ToString("ddd d MMM, HH:mm");
        return $"{start:ddd d MMM, HH:mm} – {endText}";
    }

    private sealed class SlotForm
    {
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public SlotType SlotType { get; set; } = SlotType.Instant;
        public int Weeks { get; set; } = 1;
    }
}
